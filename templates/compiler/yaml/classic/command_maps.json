{
  "_comment": "webCoRE command -> HA service per target domain. Editable data (template band). A value is either a service string, or {service, data} where data values may use $1/$2 (first/second task param) with an optional |transform, or a literal constant. Transforms live in emit_yaml.py (_PARAM_TRANSFORMS): hex_rgb turns '#rrggbb' (or a colour name from value_maps.color_names) into [r,g,b]; pct_float turns 0-100 into 0.0-1.0. All HA service names here were verified against a live HA 2026.7 service list.",
  "_piston_scope": [
    "setVariable",
    "setState",
    "saveStateLocally",
    "saveState",
    "loadStateLocally",
    "loadState",
    "log",
    "setPistonState",
    "setTileColor",
    "setTileTitle",
    "setTileText",
    "setTile",
    "clearTile",
    "exit",
    "break",
    "cancelTasks",
    "cancelPendingTasks",
    "executePiston",
    "pausePiston",
    "resumePiston",
    "httpRequest",
    "setLocationMode",
    "storeMedia",
    "wolRequest",
    "iftttMaker",
    "writeToFuelStream",
    "comment",
    "waitForTime",
    "waitForDateTime",
    "repeatAction",
    "followUp",
    "setHSMStatus"
  ],
  "on": {
    "light": "light.turn_on",
    "switch": "switch.turn_on",
    "fan": "fan.turn_on",
    "media_player": "media_player.turn_on",
    "climate": "climate.turn_on",
    "siren": "siren.turn_on",
    "camera": "camera.turn_on"
  },
  "off": {
    "light": "light.turn_off",
    "switch": "switch.turn_off",
    "fan": "fan.turn_off",
    "media_player": "media_player.turn_off",
    "climate": "climate.turn_off",
    "siren": "siren.turn_off",
    "camera": "camera.turn_off"
  },
  "toggle": {
    "light": "light.toggle",
    "switch": "switch.toggle",
    "fan": "fan.toggle",
    "media_player": "media_player.toggle",
    "climate": "climate.toggle",
    "siren": "siren.toggle",
    "cover": "cover.toggle"
  },
  "setLevel": {
    "light": {
      "service": "light.turn_on",
      "data": {
        "brightness_pct": "$1"
      }
    },
    "fan": {
      "service": "fan.set_percentage",
      "data": {
        "percentage": "$1"
      }
    },
    "media_player": {
      "service": "media_player.volume_set",
      "data": {
        "volume_level": "$1|pct_float"
      }
    }
  },
  "setColor": {
    "light": {
      "service": "light.turn_on",
      "data": {
        "rgb_color": "$1|hex_rgb"
      }
    }
  },
  "setAdjustedColor": {
    "light": {
      "service": "light.turn_on",
      "data": {
        "rgb_color": "$1|hex_rgb"
      }
    }
  },
