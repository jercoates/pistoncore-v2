{#- ─ entity_id block, single scalar or list, at a given indent ─ -#}
{%- macro entity_ids(entities, pad) -%}
{%- if entities|length == 1 %}
{{ pad }}entity_id: {{ entities[0] }}
{%- else %}
{{ pad }}entity_id:
{%- for e in entities %}
{{ pad }}  - {{ e }}
{%- endfor %}
{%- endif %}
{%- endmacro -%}

{%- macro trigger_block(t) -%}
{%- if t.kind == 'state' -%}
- trigger: state
{{- entity_ids(t.entities, '  ') }}
{%- if t.get('to') %}
{%- if t.get('to') is not sequence or t.get('to') is string %}
  to: "{{ t.get('to') }}"
{%- else %}
  to:
{%- for v in t.get('to') %}
    - "{{ v }}"
{%- endfor %}
{%- endif %}
{%- endif %}
{%- if t.get('from') %}
{%- if t.get('from') is not sequence or t.get('from') is string %}
  from: "{{ t.get('from') }}"
{%- else %}
  from:
{%- for v in t.get('from') %}
    - "{{ v }}"
{%- endfor %}
{%- endif %}
{%- endif %}
{%- elif t.kind == 'numeric_state' -%}
- trigger: numeric_state
{{- entity_ids(t.entities, '  ') }}
{%- if t.get('above') is not none %}
  above: {{ t.get('above') }}
{%- endif %}
{%- if t.get('below') is not none %}
  below: {{ t.get('below') }}
{%- endif %}
{%- if t.get('for') %}
  for: "{{ t.get('for') }}"
{%- endif %}
{%- elif t.kind == 'sun' -%}
- trigger: sun
  event: {{ t.event }}
{%- if t.get('offset') %}
  offset: "{{ t.get('offset') }}"
{%- endif %}
{%- elif t.kind == 'time' -%}
- trigger: time
  at: "{{ t.at }}"
{%- elif t.kind == 'time_pattern' -%}
- trigger: time_pattern
{%- if t.get('hours') is not none %}
  hours: "{{ t.get('hours') }}"
{%- endif %}
{%- if t.get('minutes') is not none %}
  minutes: "{{ t.get('minutes') }}"
{%- endif %}
{%- if t.get('seconds') is not none %}
  seconds: "{{ t.get('seconds') }}"
{%- endif %}
{%- endif %}
{%- if t.kind == 'state' and t.get('for') %}
  for: "{{ t.get('for') }}"
{%- endif %}
{%- if t.get('id') %}
  id: {{ t.get('id') }}
{%- endif %}
{%- endmacro -%}

{%- macro cond_block(c) -%}
{%- if c.kind == 'template' -%}
- condition: template
  value_template: "{{ c.template }}"
{%- elif c.kind == 'time' -%}
- condition: time
{%- if c.get('after') %}
  after: "{{ c.get('after') }}"
{%- endif %}
{%- if c.get('before') %}
  before: "{{ c.get('before') }}"
{%- endif %}
{%- elif c.kind == 'sun' -%}
- condition: sun
{%- if c.get('after') %}
  after: {{ c.get('after') }}
{%- endif %}
{%- if c.get('before') %}
  before: {{ c.get('before') }}
{%- endif %}
{%- elif c.kind in ('and', 'or') -%}
- condition: {{ c.kind }}
  conditions:
{%- for k in c.conditions %}
{{ cond_block(k) | indent(4, true) }}
{%- endfor %}
{%- elif c.kind == 'trigger' -%}
- condition: trigger
  id: {{ c.id }}
{%- endif %}
{%- endmacro -%}

{%- macro action_block(a) -%}
{%- if a.kind == 'delay' -%}
- delay: "{{ a.delay }}"
{%- elif a.kind == 'service' -%}
- action: {{ a.service }}
{%- if a.get('data') %}
  data:
{%- for k, v in a.get('data').items() %}
    {{ k }}: {{ v }}
{%- endfor %}
{%- endif %}
{%- if a.entities %}
  target:
{{- entity_ids(a.entities, '    ') }}
{%- endif %}
{%- elif a.kind == 'variables' -%}
- variables:
{%- for k, v in a.vars.items() %}
    {{ k }}: {{ v }}
{%- endfor %}
{%- elif a.kind == 'if' -%}
- if:
{%- for c in a.conditions %}
{{ cond_block(c) | indent(4, true) }}
{%- endfor %}
{%- if a.get('then') %}
  then:
{%- for x in a.get('then') %}
{{ action_block(x) | indent(4, true) }}
{%- endfor %}
{%- else %}
  then: []
{%- endif %}
{%- if a.get('else') %}
  else:
{%- for x in a.get('else') %}
{{ action_block(x) | indent(4, true) }}
{%- endfor %}
{%- endif %}
{%- endif %}
{%- endmacro -%}
- id: {{ auto_id }}
  alias: "{{ alias }}"
  mode: {{ mode }}
  triggers:
{%- for t in triggers %}
{{ trigger_block(t) | indent(4, true) }}
{%- endfor %}
{%- if conditions %}
  conditions:
{%- for c in conditions %}
{{ cond_block(c) | indent(4, true) }}
{%- endfor %}
{%- endif %}
{%- if actions %}
  actions:
{%- for a in actions %}
{{ action_block(a) | indent(4, true) }}
{%- endfor %}
{%- else %}
  actions: []
{%- endif %}
