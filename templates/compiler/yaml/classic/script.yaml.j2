{#- Script band — a piston with no subscriptions is not an automation, it is a
    runnable sequence (HA_YAML_COMPILER_RESEARCH §2: "execute piston with args,
    wait/nowait" -> `action: script.X` waits, `script.turn_on` doesn't). This
    is what webCoRE's Test button and executePiston target. Merged-named
    include, so the top-level key IS the script's object_id. -#}
{%- macro entity_ids(entities, pad) -%}
{%- if entities|length == 1 %}
{{ pad }}entity_id: {{ entities[0] }}
{%- else %}
{{ pad }}entity_id:
{%- for e in entities %}
{{ pad }}  - {{ e }}
{%- endfor %}
{%- endif %}
{%- endmacro -%}

{%- macro cond_block(c) -%}
{%- if c.kind == 'template' -%}
- condition: template
  value_template: "{{ c.template }}"
{%- elif c.kind == 'time' -%}
- condition: time
{%- if c.get('after') %}
  after: "{{ c.get('after') }}"
{%- endif %}
{%- if c.get('before') %}
  before: "{{ c.get('before') }}"
{%- endif %}
{%- elif c.kind == 'sun' -%}
- condition: sun
{%- if c.get('after') %}
  after: {{ c.get('after') }}
{%- endif %}
{%- if c.get('before') %}
  before: {{ c.get('before') }}
{%- endif %}
{%- elif c.kind in ('and', 'or') -%}
- condition: {{ c.kind }}
  conditions:
{%- for k in c.conditions %}
{{ cond_block(k) | indent(4, true) }}
{%- endfor %}
{%- endif %}
{%- endmacro -%}

{%- macro action_block(a) -%}
{%- if a.kind == 'delay' -%}
- delay: "{{ a.delay }}"
{%- elif a.kind == 'variables' -%}
- variables:
{%- for k, v in a.vars.items() %}
    {{ k }}: {{ v }}
{%- endfor %}
{%- elif a.kind == 'service' -%}
- action: {{ a.service }}
{%- if a.get('data') %}
  data:
{%- for k, v in a.get('data').items() %}
    {{ k }}: {{ v }}
{%- endfor %}
{%- endif %}
{%- if a.entities %}
  target:
{{- entity_ids(a.entities, '    ') }}
{%- endif %}
{%- elif a.kind == 'choose' -%}
- choose:
{%- for o in a.options %}
    - conditions:
{%- for c in o.conditions %}
{{ cond_block(c) | indent(8, true) }}
{%- endfor %}
      sequence:
{%- if o.sequence %}
{%- for x in o.sequence %}
{{ action_block(x) | indent(8, true) }}
{%- endfor %}
{%- else %}
        []
{%- endif %}
{%- endfor %}
{%- if a.get('default') %}
  default:
{%- for x in a.get('default') %}
{{ action_block(x) | indent(4, true) }}
{%- endfor %}
{%- endif %}
{%- elif a.kind == 'repeat' -%}
- repeat:
{%- if a.get('count') is not none %}
    count: {{ a.get('count') }}
{%- endif %}
{%- if a.get('while') %}
    while:
{%- for c in a.get('while') %}
{{ cond_block(c) | indent(6, true) }}
{%- endfor %}
{%- endif %}
{%- if a.get('until') %}
    until:
{%- for c in a.get('until') %}
{{ cond_block(c) | indent(6, true) }}
{%- endfor %}
{%- endif %}
    sequence:
{%- if a.body %}
{%- for x in a.body %}
{{ action_block(x) | indent(6, true) }}
{%- endfor %}
{%- else %}
      []
{%- endif %}
{%- elif a.kind == 'stop' -%}
- stop: "piston exited"
{%- elif a.kind == 'if' -%}
- if:
{%- for c in a.conditions %}
{{ cond_block(c) | indent(4, true) }}
{%- endfor %}
{%- if a.get('then') %}
  then:
{%- for x in a.get('then') %}
{{ action_block(x) | indent(4, true) }}
{%- endfor %}
{%- else %}
  then: []
{%- endif %}
{%- if a.get('else') %}
  else:
{%- for x in a.get('else') %}
{{ action_block(x) | indent(4, true) }}
{%- endfor %}
{%- endif %}
{%- endif %}
{%- endmacro -%}
{{ script_id }}:
  alias: "{{ alias }}"
  mode: {{ mode }}
  sequence:
{%- if actions %}
{%- for a in actions %}
{{ action_block(a) | indent(4, true) }}
{%- endfor %}
{%- else %}
    []
{%- endif %}
