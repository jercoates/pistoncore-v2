# ── webCoRE expression runtime (band-editable: add functions here AND to
#    _FUNCTIONS in shim/compiler/expression.py). Semantics follow the engine's
#    dynamic typing: values coerce at evaluation time, never at compile time.


def _num(x, default=0):
    try:
        f = float(x)
        return int(f) if f == int(f) else f
    except (TypeError, ValueError):
        return default


def _int(x):
    return int(_num(x))


def _truthy(x):
    if x is None:
        return False
    if isinstance(x, str):
        return x.strip().lower() not in ("", "false", "0", "off", "no", "null",
                                          "unknown", "unavailable", "none")
    return bool(x)


def _both_numeric(a, b):
    try:
        float(a), float(b)
        return True
    except (TypeError, ValueError):
        return False


def _op(a, o, b):
    """webCoRE binary operator with runtime coercion: numeric when both sides
    are numeric, string behavior otherwise ('+' concatenates)."""
    numeric = _both_numeric(a, b)
    if o == "+":
        if numeric:
            return _num(a) + _num(b)
        return ("" if a is None else str(a)) + ("" if b is None else str(b))
    if o == "-":
        return _num(a) - _num(b)
    if o == "*":
        return _num(a) * _num(b)
    if o in ("/",):
        d = _num(b)
        return _num(a) / d if d else 0
    if o == "\\":
        d = _num(b)
        return int(_num(a) // d) if d else 0
    if o == "%":
        d = _num(b)
        return _num(a) % d if d else 0
    if o == "**":
        return _num(a) ** _num(b)
    if o in ("==",):
        if numeric:
            return _num(a) == _num(b)
        return str(a).strip().lower() == str(b).strip().lower()
    if o in ("!=", "<>"):
        return not _op(a, "==", b)
    if o == ">":
        return _num(a) > _num(b) if numeric else str(a) > str(b)
    if o == "<":
        return _num(a) < _num(b) if numeric else str(a) < str(b)
    if o == ">=":
        return _num(a) >= _num(b) if numeric else str(a) >= str(b)
    if o == "<=":
        return _num(a) <= _num(b) if numeric else str(a) <= str(b)
    if o == "&&":
        return _truthy(a) and _truthy(b)
    if o == "||":
        return _truthy(a) or _truthy(b)
    if o == "^^":
        return _truthy(a) != _truthy(b)
    if o == "!&":
        return not (_truthy(a) and _truthy(b))
    if o == "!|":
        return not (_truthy(a) or _truthy(b))
    if o == "!^":
        return _truthy(a) == _truthy(b)
    if o == "&":
        return _int(a) & _int(b)
    if o == "|":
        return _int(a) | _int(b)
    if o == "^":
        return _int(a) ^ _int(b)
    if o == "<<":
        return _int(a) << _int(b)
    if o == ">>":
        return _int(a) >> _int(b)
    log.warning(f"unsupported operator {o}")
    return None


# ── time helpers (webCoRE times are epoch milliseconds) ─────────────────────

def _now_ms():
    return int(datetime.datetime.now().timestamp() * 1000)


def _utc_ms():
    return int(datetime.datetime.now(datetime.timezone.utc)
               .replace(tzinfo=None).timestamp() * 1000)


def _sysdate(fmt):
    return datetime.datetime.now().strftime(fmt)


def _sysnum(part):
    now = datetime.datetime.now()
    if part == "hour12":
        return now.hour % 12 or 12
    if part == "dow":
        return (now.weekday() + 1) % 7  # webCoRE: Sunday = 0
    return getattr(now, part)


def _daytime_ms(h, m):
    now = datetime.datetime.now()
    return int(now.replace(hour=h, minute=m, second=0, microsecond=0)
               .timestamp() * 1000)


def _sun_ms(which):
    try:
        v = state.getattr("sun.sun").get(which)
        return int(datetime.datetime.fromisoformat(str(v)).timestamp() * 1000)
    except Exception:
        return None


def _to_dt(v):
    """epoch ms / iso string / datetime -> datetime."""
    if isinstance(v, datetime.datetime):
        return v
    n = _num(v, None)
    if n is not None and n > 10000000:
        return datetime.datetime.fromtimestamp(n / 1000)
    try:
        return datetime.datetime.fromisoformat(str(v))
    except (TypeError, ValueError):
        return datetime.datetime.now()


# ── function library ────────────────────────────────────────────────────────

def _fn_lower(s):
    return str(s or "").lower()


def _fn_upper(s):
    return str(s or "").upper()


def _fn_trim(s):
    return str(s or "").strip()


def _fn_left(s, n):
    return str(s or "")[:_int(n)]


def _fn_right(s, n):
    return str(s or "")[-_int(n):] if _int(n) else ""


def _fn_mid(s, start, length=None):
    s = str(s or "")
    start = _int(start)
    return s[start:start + _int(length)] if length is not None else s[start:]


def _fn_substring(s, start, length=None):
    return _fn_mid(s, start, length)


def _fn_replace(s, *pairs):
    s = str(s or "")
    for i in range(0, len(pairs) - 1, 2):
        s = s.replace(str(pairs[i]), str(pairs[i + 1]))
    return s


def _fn_concat(*args):
    return "".join("" if a is None else str(a) for a in args)


def _fn_contains(s, needle):
    return str(needle) in str(s or "")


def _fn_startswith(s, needle):
    return str(s or "").startswith(str(needle))


def _fn_endswith(s, needle):
    return str(s or "").endswith(str(needle))


def _fn_indexof(haystack, needle):
    if isinstance(haystack, (list, tuple)):
        for i, x in enumerate(haystack):
            if str(x) == str(needle):
                return i
        return -1
    return str(haystack or "").find(str(needle))


def _fn_length(s):
    return len(s) if isinstance(s, (list, tuple)) else len(str(s or ""))


def _fn_count(x):
    return len(x) if isinstance(x, (list, tuple)) else (_fn_length(x) and 1)


def _fn_arrayitem(index, arr):
    if not isinstance(arr, (list, tuple)):
        return None
    i = _int(index)
    return arr[i] if 0 <= i < len(arr) else None


def _fn_item(index, arr):
    return _fn_arrayitem(index, arr)


def _fn_string(x):
    return "" if x is None else str(x)


def _fn_format(fmt, *args):
    try:
        return str(fmt) % tuple(args)
    except (TypeError, ValueError):
        return str(fmt)


def _fn_sprintf(fmt, *args):
    return _fn_format(fmt, *args)


def _fn_int(x):
    return _int(x)


def _fn_integer(x):
    return _int(x)


def _fn_decimal(x):
    return float(_num(x))


def _fn_float(x):
    return float(_num(x))


def _fn_number(x):
    return _num(x)


def _fn_round(x, digits=0):
    r = round(float(_num(x)), _int(digits))
    return _int(r) if not _int(digits) else r


def _fn_floor(x):
    return math.floor(_num(x))


def _fn_ceil(x):
    return math.ceil(_num(x))


def _fn_abs(x):
    return abs(_num(x))


def _fn_min(*args):
    vals = [_num(a) for a in _flatten(args)]
    return min(vals) if vals else None


def _fn_max(*args):
    vals = [_num(a) for a in _flatten(args)]
    return max(vals) if vals else None


def _fn_sum(*args):
    return sum(_num(a) for a in _flatten(args))


def _fn_avg(*args):
    vals = [_num(a) for a in _flatten(args)]
    return sum(vals) / len(vals) if vals else 0


def _fn_median(*args):
    vals = sorted(_num(a) for a in _flatten(args))
    return vals[len(vals) // 2] if vals else 0


def _fn_power(x, p):
    return _num(x) ** _num(p)


def _fn_sqrt(x):
    return math.sqrt(_num(x))


def _fn_random(*args):
    nums = [a for a in args if _both_numeric(a, 0)]
    if len(args) == 0:
        return random.random()
    if len(args) == 1 and nums:
        return random.randint(0, _int(args[0]))
    if len(args) == 2 and len(nums) == 2:
        return random.randint(_int(args[0]), _int(args[1]))
    return random.choice(args)


def _fn_isempty(x):
    return x is None or str(x).strip() == ""


def _fn_coalesce(*args):
    for a in args:
        if not _fn_isempty(a):
            return a
    return None


def _fn_boolean(x):
    return _truthy(x)


def _fn_bool(x):
    return _truthy(x)


def _fn_isbetween(v, a, b):
    v, a, b = _num(v), _num(a), _num(b)
    # time-of-day coercion: bounds are ms-since-midnight but v is an epoch
    # timestamp (isBetween($now, time('04:00'), time('23:00'))) -> compare
    # v's time-of-day, matching the engine's cast-to-common-type behavior
    if v > 86400000 >= max(a, b):
        dt = _to_dt(v)
        v = (dt.hour * 3600 + dt.minute * 60 + dt.second) * 1000
    return a <= v <= b if a <= b else (v >= a or v <= b)


def _fn_time(v):
    """time('16:30') / time(epoch-ms) -> ms since midnight (webCoRE time)."""
    if _both_numeric(v, 0):
        dt = _to_dt(v)
        return (dt.hour * 3600 + dt.minute * 60 + dt.second) * 1000
    try:
        parts = str(v).replace("AM", "").replace("PM", "").strip().split(":")
        h, m = _int(parts[0]), _int(parts[1] if len(parts) > 1 else 0)
        s = _int(parts[2]) if len(parts) > 2 else 0
        if "PM" in str(v).upper() and h < 12:
            h += 12
        return (h * 3600 + m * 60 + s) * 1000
    except Exception:
        return 0


def _fn_date(v):
    dt = _to_dt(v)
    return int(dt.replace(hour=0, minute=0, second=0, microsecond=0)
               .timestamp() * 1000)


def _fn_datetime(v):
    return int(_to_dt(v).timestamp() * 1000)


def _fn_addseconds(v, s):
    return _fn_datetime(v) + _int(s) * 1000


def _fn_addminutes(v, m):
    return _fn_datetime(v) + _int(m) * 60000


def _fn_addhours(v, h):
    return _fn_datetime(v) + _int(h) * 3600000


def _fn_adddays(v, d):
    return _fn_datetime(v) + _int(d) * 86400000


_JAVA_FMT = [("EEEE", "%A"), ("EEE", "%a"), ("MMMM", "%B"), ("MMM", "%b"),
             ("yyyy", "%Y"), ("yy", "%y"), ("MM", "%m"), ("dd", "%d"),
             ("HH", "%H"), ("hh", "%I"), ("mm", "%M"), ("ss", "%S"),
             ("a", "%p"), ("h", "%I"), ("H", "%H"), ("d", "%d"), ("M", "%m")]


def _fn_formatdatetime(v, fmt="yyyy-MM-dd HH:mm:ss"):
    """Java SimpleDateFormat (webCoRE) -> strftime, common tokens only."""
    out = str(fmt)
    for j, p in _JAVA_FMT:
        out = out.replace(j, p)
    s = _to_dt(v).strftime(out)
    return s.replace(" 0", " ").lstrip("0") if out.startswith("%I") else s


def _fn_formatduration(ms, friendly=False, granularity="s", show_ms=False):
    total = _int(ms) // 1000
    h, rem = divmod(total, 3600)
    m, s = divmod(rem, 60)
    if granularity == "m":
        return f"{h:02d}:{m:02d}" if not friendly else f"{h}h {m}m"
    return f"{h:02d}:{m:02d}:{s:02d}" if not friendly else f"{h}h {m}m {s}s"


def _fn_age(entity_id):
    try:
        lc = state.getattr(str(entity_id)).get("last_changed")
        then = datetime.datetime.fromisoformat(str(lc))
        return int((datetime.datetime.now(then.tzinfo) - then)
                   .total_seconds() * 1000)
    except Exception:
        return None


