def _s(name):
    """Forgiving state read -> string or None (research §9 locked rule)."""
    try:
        return str(state.get(name))
    except Exception:
        return None


def _f(name):
    """Forgiving numeric state read -> float or None (research §9 locked rule)."""
    try:
        return float(state.get(name))
    except Exception:
        return None


def _time_between(a, b):
    """$time between two times, minutes since midnight, wraps past midnight."""
    now = datetime.datetime.now()
    m = now.hour * 60 + now.minute
    return (a <= m <= b) if a <= b else (m >= a or m <= b)


